<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LearningApp.Views.EditProfilePage"
             BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Top Bar ── -->
        <Grid Grid.Row="0" Padding="20,52,20,16"
              ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}">
            <Border Grid.Column="0"
                    BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#1E293B}"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#CBD5E1, Dark=#334155}"
                    WidthRequest="40" HeightRequest="40">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Label Text="←" FontSize="18"
                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </Border>
            <Label Grid.Column="1" Text="Edit Profile"
                   FontSize="16" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
            <BoxView Grid.Column="2" WidthRequest="40" Color="Transparent"/>
        </Grid>

        <!-- ── Scrollable Form ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,8,24,24" Spacing="0">

                <!-- ── Avatar Section ── -->
                <VerticalStackLayout HorizontalOptions="Center"
                                     Spacing="12" Margin="0,16,0,32">

                    <!-- Avatar grid with invisible Button on top -->
                    <Grid HorizontalOptions="Center"
                          WidthRequest="100" HeightRequest="100">

                        <!-- Avatar circle -->
                        <Border x:Name="AvatarBorder"
                                BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#1E293B}"
                                StrokeThickness="3" Stroke="#3B82F6"
                                WidthRequest="100" HeightRequest="100"
                                InputTransparent="True">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="50"/>
                            </Border.StrokeShape>
                            <Grid InputTransparent="True">
                                <Label x:Name="AvatarEmoji"
                                       Text="👤" FontSize="52"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       InputTransparent="True"/>
                                <Image x:Name="AvatarImage"
                                       Aspect="AspectFill"
                                       IsVisible="False"
                                       HorizontalOptions="Fill"
                                       VerticalOptions="Fill"
                                       InputTransparent="True"/>
                            </Grid>
                        </Border>

                        <!-- Camera badge -->
                        <Border BackgroundColor="#3B82F6"
                                StrokeThickness="2"
                                Stroke="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                WidthRequest="32" HeightRequest="32"
                                HorizontalOptions="End" VerticalOptions="End"
                                Margin="0,0,2,2"
                                InputTransparent="True">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Label Text="📷" FontSize="14"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   InputTransparent="True"/>
                        </Border>

                        <!-- Invisible Button — reliable tap on Android -->
                        <Button Text=""
                                BackgroundColor="Transparent"
                                BorderWidth="0"
                                WidthRequest="100" HeightRequest="100"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill"
                                Clicked="OnChangeAvatarClicked"/>

                    </Grid>

                    <Label Text="Tap camera to change photo"
                           FontSize="12" TextColor="#64748B"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- ── Form Card ── -->
                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                        Padding="24,28">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="24">

                        <!-- Full Name -->
                        <VerticalStackLayout Spacing="0">
                            <Label Text="FULL NAME"
                                   TextColor="#475569" FontSize="11"
                                   FontAttributes="Bold" CharacterSpacing="2"
                                   Margin="0,0,0,8"/>
                            <Entry x:Name="FullNameEntry"
                                   Placeholder="Enter your full name"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                                   PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#334155}"
                                   FontSize="16"
                                   BackgroundColor="Transparent"
                                   Margin="0,-6,0,-6"/>
                            <BoxView HeightRequest="1"
                                     BackgroundColor="{AppThemeBinding Light=#CBD5E1, Dark=#475569}"/>
                            <Label x:Name="FullNameError"
                                   TextColor="#EF4444" FontSize="12"
                                   Margin="0,6,0,0" IsVisible="False"/>
                        </VerticalStackLayout>

                        <!-- Current Password -->
                        <VerticalStackLayout Spacing="0">
                            <Label Text="CURRENT PASSWORD"
                                   TextColor="#475569" FontSize="11"
                                   FontAttributes="Bold" CharacterSpacing="2"
                                   Margin="0,0,0,8"/>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Entry x:Name="CurrentPasswordEntry"
                                       Grid.Column="0"
                                       Placeholder="Enter current password"
                                       IsPassword="True"
                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                                       PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#334155}"
                                       FontSize="16"
                                       BackgroundColor="Transparent"
                                       Margin="0,-6,0,-6"/>
                                <Image x:Name="CurrentPasswordEyeIcon"
                                       Grid.Column="1"
                                       Source="eye_open.png"
                                       WidthRequest="22" HeightRequest="22"
                                       Aspect="AspectFit"
                                       VerticalOptions="Center"
                                       Opacity="0.5">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnToggleCurrentPassword"/>
                                    </Image.GestureRecognizers>
                                </Image>
                            </Grid>
                            <BoxView HeightRequest="1"
                                     BackgroundColor="{AppThemeBinding Light=#CBD5E1, Dark=#475569}"/>
                            <Label x:Name="CurrentPasswordError"
                                   TextColor="#EF4444" FontSize="12"
                                   Margin="0,6,0,0" IsVisible="False"/>
                        </VerticalStackLayout>

                        <!-- New Password -->
                        <VerticalStackLayout Spacing="0">
                            <Label Text="NEW PASSWORD"
                                   TextColor="#475569" FontSize="11"
                                   FontAttributes="Bold" CharacterSpacing="2"
                                   Margin="0,0,0,8"/>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Entry x:Name="NewPasswordEntry"
                                       Grid.Column="0"
                                       Placeholder="Leave blank to keep current"
                                       IsPassword="True"
                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                                       PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#334155}"
                                       FontSize="16"
                                       BackgroundColor="Transparent"
                                       Margin="0,-6,0,-6"/>
                                <Image x:Name="NewPasswordEyeIcon"
                                       Grid.Column="1"
                                       Source="eye_open.png"
                                       WidthRequest="22" HeightRequest="22"
                                       Aspect="AspectFit"
                                       VerticalOptions="Center"
                                       Opacity="0.5">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnToggleNewPassword"/>
                                    </Image.GestureRecognizers>
                                </Image>
                            </Grid>
                            <BoxView HeightRequest="1"
                                     BackgroundColor="{AppThemeBinding Light=#CBD5E1, Dark=#475569}"/>
                            <Label x:Name="NewPasswordError"
                                   TextColor="#EF4444" FontSize="12"
                                   Margin="0,6,0,0" IsVisible="False"/>
                        </VerticalStackLayout>

                        <!-- Confirm New Password -->
                        <VerticalStackLayout Spacing="0">
                            <Label Text="CONFIRM NEW PASSWORD"
                                   TextColor="#475569" FontSize="11"
                                   FontAttributes="Bold" CharacterSpacing="2"
                                   Margin="0,0,0,8"/>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Entry x:Name="ConfirmPasswordEntry"
                                       Grid.Column="0"
                                       Placeholder="Re-enter new password"
                                       IsPassword="True"
                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                                       PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#334155}"
                                       FontSize="16"
                                       BackgroundColor="Transparent"
                                       Margin="0,-6,0,-6"/>
                                <Image x:Name="ConfirmPasswordEyeIcon"
                                       Grid.Column="1"
                                       Source="eye_open.png"
                                       WidthRequest="22" HeightRequest="22"
                                       Aspect="AspectFit"
                                       VerticalOptions="Center"
                                       Opacity="0.5">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnToggleConfirmPassword"/>
                                    </Image.GestureRecognizers>
                                </Image>
                            </Grid>
                            <BoxView HeightRequest="1"
                                     BackgroundColor="{AppThemeBinding Light=#CBD5E1, Dark=#475569}"/>
                            <Label x:Name="ConfirmPasswordError"
                                   TextColor="#EF4444" FontSize="12"
                                   Margin="0,6,0,0" IsVisible="False"/>
                        </VerticalStackLayout>

                        <!-- API Error Banner -->
                        <Border x:Name="ErrorBanner"
                                BackgroundColor="#7F1D1D20"
                                StrokeThickness="1" Stroke="#EF4444"
                                Padding="14,10" IsVisible="False">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Label x:Name="ErrorBannerText"
                                   TextColor="#EF4444" FontSize="13"
                                   HorizontalOptions="Center"/>
                        </Border>

                        <!-- Success Banner -->
                        <Border x:Name="SuccessBanner"
                                BackgroundColor="#14532D20"
                                StrokeThickness="1" Stroke="#22C55E"
                                Padding="14,10" IsVisible="False">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Label Text="✅  Profile updated successfully!"
                                   TextColor="#22C55E" FontSize="13"
                                   HorizontalOptions="Center"/>
                        </Border>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Save Button ── -->
        <Grid Grid.Row="2" Padding="24,12,24,36"
              BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}">
            <Border BackgroundColor="#3B82F6" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <Button x:Name="SaveBtn"
                        Text="Save Changes"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="16" FontAttributes="Bold"
                        HeightRequest="54"
                        Clicked="OnSaveTapped"/>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
