<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:LearningApp.Controls"
             x:Class="LearningApp.Views.MainPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0F172A">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="25">

                <!-- Welcome Header -->
                <VerticalStackLayout Spacing="4" Margin="0,10,0,0">
                    <Label x:Name="WelcomeLabel" Text="Welcome back!"
                           FontSize="28" FontAttributes="Bold" TextColor="#F8FAFC"/>
                    <Label Text="Ready to learn something new?"
                           FontSize="14" TextColor="#F8FAFC"/>
                </VerticalStackLayout>

                <!-- Search Bar -->
                <Border StrokeThickness="0" 
                    Background="#1E293B" 
                    HeightRequest="50"
                    Padding="15,0"> 
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Text="⌕" TextColor="#94A3B8" FontSize="20" VerticalOptions="Center"/>
                        <Entry Grid.Column="1" 
               Placeholder="Search for courses..."
               PlaceholderColor="#64748B"
               TextColor="White"
               BackgroundColor="Transparent"/>
                    </Grid>
                </Border>

                <!-- Categories Header -->
                <Grid>
                    <Label Text="Categories" FontSize="20"
                           FontAttributes="Bold" TextColor="White"/>
                    <Label Text="See all" FontSize="14" TextColor="#38BDF8"
                           FontAttributes="Bold" HorizontalOptions="End"
                           VerticalOptions="Center"/>
                </Grid>

                <!-- Skeleton State -->
                <Grid x:Name="SkeletonGrid"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnDefinitions="*,*"
                      RowSpacing="15" ColumnSpacing="15"
                      IsVisible="True">
                    <controls:SkeletonView Grid.Row="0" Grid.Column="0" HeightRequest="120" CornerRadius="20"/>
                    <controls:SkeletonView Grid.Row="0" Grid.Column="1" HeightRequest="120" CornerRadius="20"/>
                    <controls:SkeletonView Grid.Row="1" Grid.Column="0" HeightRequest="120" CornerRadius="20"/>
                    <controls:SkeletonView Grid.Row="1" Grid.Column="1" HeightRequest="120" CornerRadius="20"/>
                    <controls:SkeletonView Grid.Row="2" Grid.Column="0" HeightRequest="120" CornerRadius="20"/>
                    <controls:SkeletonView Grid.Row="2" Grid.Column="1" HeightRequest="120" CornerRadius="20"/>
                    <controls:SkeletonView Grid.Row="3" Grid.Column="0" HeightRequest="120" CornerRadius="20"/>
                    <controls:SkeletonView Grid.Row="3" Grid.Column="1" HeightRequest="120" CornerRadius="20"/>
                </Grid>

                <!-- Real Category Grid -->
                <Grid x:Name="CategoryGrid"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnDefinitions="*,*"
                      RowSpacing="15" ColumnSpacing="15"
                      IsVisible="False">

                    <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#1E293B" Stroke="#333333" StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="PHP"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Border BackgroundColor="#7B7FB8" HeightRequest="45" WidthRequest="45" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Label Text="PHP" FontSize="14" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="PHP" FontSize="16" FontAttributes="Bold" TextColor="#94A3B8"/>
                            <Label Text="5 assessments" FontSize="12" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#1E293B" Stroke="#333333" StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="Java"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Border BackgroundColor="#F89820" HeightRequest="45" WidthRequest="45" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Label Text="☕" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Java" FontSize="16" FontAttributes="Bold" TextColor="#94A3B8"/>
                            <Label Text="5 assessments" FontSize="12" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" BackgroundColor="#1E293B" Stroke="#333333" StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="JavaScript"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Border BackgroundColor="#F0DB4F" HeightRequest="45" WidthRequest="45" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Label Text="JS" FontSize="14" FontAttributes="Bold" TextColor="Black" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="JavaScript" FontSize="16" FontAttributes="Bold" TextColor="#94A3B8"/>
                            <Label Text="5 assessments" FontSize="12" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#1E293B" Stroke="#333333" StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="Python"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Border BackgroundColor="#4584B6" HeightRequest="45" WidthRequest="45" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Label Text="🐍" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Python" FontSize="16" FontAttributes="Bold" TextColor="#94A3B8"/>
                            <Label Text="5 assessments" FontSize="12" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="0" BackgroundColor="#1E293B" Stroke="#333333" StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="C++"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Border BackgroundColor="#659AD2" HeightRequest="45" WidthRequest="45" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Label Text="C++" FontSize="14" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="C++" FontSize="16" FontAttributes="Bold" TextColor="#94A3B8"/>
                            <Label Text="5 assessments" FontSize="12" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="1" BackgroundColor="#1E293B" Stroke="#333333" StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="C"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Border BackgroundColor="#A8B9CC" HeightRequest="45" WidthRequest="45" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Label Text="C" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="C" FontSize="16" FontAttributes="Bold" TextColor="#94A3B8"/>
                            <Label Text="5 assessments" FontSize="12" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="3" Grid.Column="0" BackgroundColor="#1E293B" Stroke="#333333" StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="C#"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Border BackgroundColor="#68217A" HeightRequest="45" WidthRequest="45" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Label Text="C#" FontSize="14" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="C#" FontSize="16" FontAttributes="Bold" TextColor="#94A3B8"/>
                            <Label Text="5 assessments" FontSize="12" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="3" Grid.Column="1" BackgroundColor="#1E293B" Stroke="#333333" StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="MySQL"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Border BackgroundColor="#00758F" HeightRequest="45" WidthRequest="45" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Label Text="SQL" FontSize="14" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="MySQL" FontSize="16" FontAttributes="Bold" TextColor="#94A3B8"/>
                            <Label Text="5 assessments" FontSize="12" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Featured Course skeleton -->
                <Label Text="Featured Courses" FontSize="20"
                       FontAttributes="Bold" TextColor="White" Margin="0,10,0,0"/>
                <controls:SkeletonView x:Name="FeaturedSkeleton" HeightRequest="220" CornerRadius="24"/>

                <!-- Featured Course real -->
                <Border x:Name="FeaturedCourse"
                        BackgroundColor="#1A1A1A" Stroke="#333333" StrokeThickness="1"
                        Padding="0" Margin="0,0,0,20" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFeaturedCourseTapped"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout>
                        <Border BackgroundColor="#503B31" HeightRequest="150" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="24,24,0,0"/>
                            </Border.StrokeShape>
                            <Label Text="💻" FontSize="60" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Padding="16" Spacing="5">
                            <Label Text="Complete Web Development Course"
                                   FontSize="16" FontAttributes="Bold" TextColor="White"/>
                            <Label Text="By: Martin, Romualdez" FontSize="13" TextColor="#9097C0"/>
                            <Label Text="52 hours" FontSize="13" TextColor="#A7BBEC" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <BoxView HeightRequest="40" Color="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
