<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:LearningApp.Controls"
             x:Class="LearningApp.Views.MainPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="25">

                <!-- Welcome Header -->
                <VerticalStackLayout Spacing="4" Margin="0,10,0,0">
                    <Label x:Name="WelcomeLabel" Text="Welcome back!"
                           FontSize="28" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                    <Label Text="Ready to learn something new?"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}"/>
                </VerticalStackLayout>

                <!-- Search Bar -->
                <Border StrokeThickness="0"
                        Background="{AppThemeBinding Light=#E2E8F0, Dark=#1E293B}"
                        HeightRequest="50"
                        Padding="15,5">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Text="⌕"
                               TextColor="#94A3B8"
                               FontSize="20" VerticalOptions="Center"/>
                        <Entry Grid.Column="1"
                               Placeholder="Search for courses..."
                               PlaceholderColor="#64748B"
                               TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"
                               BackgroundColor="Transparent"/>
                    </Grid>
                </Border>

                <!-- Categories Header -->
                <Grid>
                    <Label Text="Categories" FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"/>
                </Grid>

                <!-- Skeleton State -->
                <Grid x:Name="SkeletonGrid"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnDefinitions="*,*"
                      RowSpacing="15" ColumnSpacing="15"
                      IsVisible="True">
                    <controls:SkeletonView Grid.Row="0" Grid.Column="0" HeightRequest="120" CornerRadius="20"/>
                    <controls:SkeletonView Grid.Row="0" Grid.Column="1" HeightRequest="120" CornerRadius="20"/>
                    <controls:SkeletonView Grid.Row="1" Grid.Column="0" HeightRequest="120" CornerRadius="20"/>
                    <controls:SkeletonView Grid.Row="1" Grid.Column="1" HeightRequest="120" CornerRadius="20"/>
                    <controls:SkeletonView Grid.Row="2" Grid.Column="0" HeightRequest="120" CornerRadius="20"/>
                    <controls:SkeletonView Grid.Row="2" Grid.Column="1" HeightRequest="120" CornerRadius="20"/>
                    <controls:SkeletonView Grid.Row="3" Grid.Column="0" HeightRequest="120" CornerRadius="20"/>
                    <controls:SkeletonView Grid.Row="3" Grid.Column="1" HeightRequest="120" CornerRadius="20"/>
                </Grid>

                <!-- Real Category Grid -->
                <Grid x:Name="CategoryGrid"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnDefinitions="*,*"
                      RowSpacing="15" ColumnSpacing="15"
                      IsVisible="False">

                    <!-- PHP -->
                    <Border Grid.Row="0" Grid.Column="0"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#333333}"
                            StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="PHP"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Image Source="php.png" HeightRequest="45" WidthRequest="45"
                                   Aspect="AspectFit" HorizontalOptions="Center"/>
                            <Label Text="PHP" FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                            <Label Text="10 assessments" FontSize="12" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Java -->
                    <Border Grid.Row="0" Grid.Column="1"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#333333}"
                            StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="Java"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Image Source="java.png" HeightRequest="45" WidthRequest="45"
                                   Aspect="AspectFit" HorizontalOptions="Center"/>
                            <Label Text="Java" FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                            <Label Text="10 assessments" FontSize="12" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- JavaScript -->
                    <Border Grid.Row="1" Grid.Column="0"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#333333}"
                            StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="JavaScript"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Image Source="javascript.png" HeightRequest="45" WidthRequest="45"
                                   Aspect="AspectFit" HorizontalOptions="Center"/>
                            <Label Text="JavaScript" FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                            <Label Text="10 assessments" FontSize="12" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Python -->
                    <Border Grid.Row="1" Grid.Column="1"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#333333}"
                            StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="Python"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Image Source="python.png" HeightRequest="45" WidthRequest="45"
                                   Aspect="AspectFit" HorizontalOptions="Center"/>
                            <Label Text="Python" FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                            <Label Text="10 assessments" FontSize="12" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- C++ -->
                    <Border Grid.Row="2" Grid.Column="0"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#333333}"
                            StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="C++"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Image Source="cplusplus.png" HeightRequest="45" WidthRequest="45"
                                   Aspect="AspectFit" HorizontalOptions="Center"/>
                            <Label Text="C++" FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                            <Label Text="10 assessments" FontSize="12" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- C -->
                    <Border Grid.Row="2" Grid.Column="1"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#333333}"
                            StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="C"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Image Source="cprog.png" HeightRequest="45" WidthRequest="45"
                                   Aspect="AspectFit" HorizontalOptions="Center"/>
                            <Label Text="C" FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                            <Label Text="10 assessments" FontSize="12" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- C# -->
                    <Border Grid.Row="3" Grid.Column="0"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#333333}"
                            StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="C#"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Image Source="csharp.png" HeightRequest="45" WidthRequest="45"
                                   Aspect="AspectFit" HorizontalOptions="Center"/>
                            <Label Text="C#" FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                            <Label Text="10 assessments" FontSize="12" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- GO -->
                    <Border Grid.Row="3" Grid.Column="1"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#333333}"
                            StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="MySQL"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Image Source="go.png" HeightRequest="45" WidthRequest="45"
                                   Aspect="AspectFit" HorizontalOptions="Center"/>
                            <Label Text="GO" FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                            <Label Text="10 assessments" FontSize="12" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                <!-- Featured Course Header -->
                <Label Text="Featured Courses" FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"
                       Margin="0,10,0,0"/>

                <!-- Featured Course Skeleton -->
                <controls:SkeletonView x:Name="FeaturedSkeleton" HeightRequest="220" CornerRadius="24"/>

                <!-- Featured Course real -->
                <Border x:Name="FeaturedCourse"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A1A1A}"
                        Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#333333}"
                        StrokeThickness="1"
                        Padding="0" Margin="0,0,0,20" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFeaturedCourseTapped" CommandParameter="web"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout>
                        <Border BackgroundColor="#1E293B" HeightRequest="150" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="24,24,0,0"/>
                            </Border.StrokeShape>
                            <Image Source="web.jpg"
                                   Aspect="AspectFill"
                                   HorizontalOptions="Fill"
                                   VerticalOptions="Fill"
                                   HeightRequest="150"/>
                        </Border>
                        <VerticalStackLayout Padding="16" Spacing="5">
                            <Label Text="Web Development Course"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"/>
                            <Label Text="By: Youtube Academy" FontSize="13" TextColor="#9097C0"/>
                            <Label Text="52 hours" FontSize="13" TextColor="#A7BBEC" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <BoxView HeightRequest="40" Color="Transparent"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
