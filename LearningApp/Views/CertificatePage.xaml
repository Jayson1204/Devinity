<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LearningApp.Views.CertificatePage"
             BackgroundColor="#F1EDE6"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Top Bar ── -->
        <Grid Grid.Row="0" Padding="20,52,20,16"
              ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="#F1EDE6">
            <Border Grid.Column="0" BackgroundColor="White"
                    StrokeThickness="1" Stroke="#E0D9D0"
                    WidthRequest="40" HeightRequest="40">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Label Text="←" FontSize="18" TextColor="#1A1A1A"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </Border>
            <Label Grid.Column="1" Text="Certificate"
                   FontSize="16" FontAttributes="Bold"
                   TextColor="#1A1A1A" HorizontalOptions="Center"
                   VerticalOptions="Center"/>
            <Border Grid.Column="2" BackgroundColor="White"
                    StrokeThickness="1" Stroke="#E0D9D0"
                    WidthRequest="40" HeightRequest="40">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Label Text="↑" FontSize="18" TextColor="#1A1A1A"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnShareTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </Border>
        </Grid>

        <!-- ── Certificate Preview ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,8,24,24" Spacing="0">

                <Border x:Name="CertificateCard"
                        BackgroundColor="White"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#00000020" Offset="0,8" Radius="24" Opacity="1"/>
                    </Border.Shadow>

                    <Grid RowDefinitions="8,Auto,Auto,Auto,Auto,Auto,Auto,Auto,8">

                        <!-- Gold top bar -->
                        <BoxView Grid.Row="0" Color="#C9A84C" HeightRequest="8"/>

                        <!-- Blue header band -->
                        <Grid Grid.Row="1" BackgroundColor="#1B2B5E" Padding="24,20">
                            <Label Text="CERTIFICATE OF COMPLETION"
                                   FontSize="18" FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   CharacterSpacing="2"/>
                        </Grid>

                        <!-- Badge -->
                        <Grid Grid.Row="2" Padding="0,20,0,10" HorizontalOptions="Center">
                            <Ellipse Fill="#FDF6E3" WidthRequest="72" HeightRequest="72"
                                     StrokeThickness="2" Stroke="#C9A84C"/>
                            <Label Text="🎓" FontSize="32"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <!-- Proudly present to -->
                        <Label Grid.Row="3"
                               Text="PROUDLY PRESENT TO:"
                               FontSize="10" FontAttributes="Bold"
                               CharacterSpacing="2"
                               TextColor="#888888"
                               HorizontalOptions="Center"
                               Margin="0,0,0,4"/>

                        <!-- Student name -->
                        <VerticalStackLayout Grid.Row="4"
                                             HorizontalOptions="Center"
                                             Spacing="6"
                                             Margin="0,0,0,16">
                            <Label x:Name="StudentNameLabel"
                                   Text=""
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="#1B2B5E"
                                   HorizontalOptions="Center"/>
                            <BoxView HeightRequest="1.5" Color="#C9A84C"
                                     Margin="40,0"/>
                        </VerticalStackLayout>

                        <!-- Has completed -->
                        <VerticalStackLayout Grid.Row="5"
                                             HorizontalOptions="Center"
                                             Spacing="8"
                                             Margin="0,0,0,20">
                            <Label Text="has successfully completed"
                                   FontSize="12" TextColor="#666666"
                                   HorizontalOptions="Center"/>
                            <Border BackgroundColor="#FDF6E3"
                                    StrokeThickness="1" Stroke="#C9A84C"
                                    Padding="16,8" HorizontalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label x:Name="CourseNameLabel"
                                       Text=""
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#1B2B5E"
                                       HorizontalOptions="Center"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Date + ID -->
                        <Grid Grid.Row="6"
                              ColumnDefinitions="*,*"
                              Padding="28,0,28,16">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="DATE ISSUED" FontSize="8"
                                       FontAttributes="Bold" CharacterSpacing="1.5"
                                       TextColor="#AAAAAA"/>
                                <Label x:Name="IssueDateLabel" Text=""
                                       FontSize="12" FontAttributes="Bold"
                                       TextColor="#1B2B5E"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2"
                                                 HorizontalOptions="End">
                                <Label Text="CERT ID" FontSize="8"
                                       FontAttributes="Bold" CharacterSpacing="1.5"
                                       TextColor="#AAAAAA" HorizontalOptions="End"/>
                                <Label x:Name="CertIdLabel" Text=""
                                       FontSize="12" FontAttributes="Bold"
                                       TextColor="#1B2B5E" HorizontalOptions="End"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Congrats label -->
                        <Label Grid.Row="7"
                               x:Name="CongratsLabel"
                               Text=""
                               FontSize="12"
                               TextColor="#666666"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               Margin="24,0,24,16"/>

                        <!-- Gold bottom bar -->
                        <BoxView Grid.Row="8" Color="#C9A84C" HeightRequest="8"/>

                    </Grid>
                </Border>

                <!-- Congrats message below card -->
                <VerticalStackLayout Margin="0,24,0,0" Spacing="6"
                                     HorizontalOptions="Center">
                    <Label Text="🎉 Congratulations!"
                           FontSize="20" FontAttributes="Bold"
                           TextColor="#1A1A1A" HorizontalOptions="Center"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Bottom Buttons ── -->
        <Grid Grid.Row="2" Padding="24,12,24,36"
              ColumnDefinitions="*,Auto" ColumnSpacing="12"
              BackgroundColor="#F1EDE6">

            <Border Grid.Column="0" BackgroundColor="#1B2B5E" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Button Text="← My Learning"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="15" FontAttributes="Bold"
                        HeightRequest="52"
                        Clicked="OnBackTapped"/>
            </Border>

            <Border Grid.Column="1" BackgroundColor="#C9A84C"
                    StrokeThickness="0" WidthRequest="120">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Button x:Name="DownloadBtn"
                        Text="⬇ PDF"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="15" FontAttributes="Bold"
                        HeightRequest="52"
                        Clicked="OnDownloadPdfTapped"/>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
