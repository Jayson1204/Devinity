<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:LearningApp.Controls"
             x:Class="LearningApp.Views.ProfilePage"
             BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*">
        <Grid Grid.Row="0">

            <!-- Skeleton -->
            <ScrollView x:Name="SkeletonScroll" IsVisible="True">
                <VerticalStackLayout Spacing="0"
                                     BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}">
                    <VerticalStackLayout BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                         Padding="24,60,24,24" Spacing="14">
                        <controls:SkeletonView WidthRequest="80" HeightRequest="80"
                                               CornerRadius="40" HorizontalOptions="Start"/>
                        <controls:SkeletonView HeightRequest="22" WidthRequest="160"
                                               CornerRadius="6" HorizontalOptions="Start"/>
                        <controls:SkeletonView HeightRequest="14" WidthRequest="220"
                                               CornerRadius="6" HorizontalOptions="Start"/>
                    </VerticalStackLayout>
                    <Grid ColumnDefinitions="*,*,*" Padding="24,0,24,24" ColumnSpacing="12">
                        <controls:SkeletonView Grid.Column="0" HeightRequest="100" CornerRadius="20"/>
                        <controls:SkeletonView Grid.Column="1" HeightRequest="100" CornerRadius="20"/>
                        <controls:SkeletonView Grid.Column="2" HeightRequest="100" CornerRadius="20"/>
                    </Grid>
                    <VerticalStackLayout Padding="24,0" Spacing="12">
                        <controls:SkeletonView HeightRequest="60" CornerRadius="16"/>
                        <controls:SkeletonView HeightRequest="60" CornerRadius="16"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>

            <!-- Real Content -->
            <ScrollView x:Name="ContentScroll" IsVisible="False">
                <VerticalStackLayout Spacing="0"
                                     BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}">

                    <!-- ── Top Bar ── -->
                    <Grid ColumnDefinitions="*,Auto" Padding="24,60,24,0">
                        <Label Grid.Column="0"
                               Text="Profile"
                               FontSize="26" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                               VerticalOptions="Center"/>
                    </Grid>

                    <!-- ── Profile Header ── -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16"
                          Padding="24,24,24,0">

                        <!-- ── Avatar (tappable) ── CHANGED: added tap + camera badge -->
                        <Grid Grid.Column="0">

                            <Border BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#1E293B}"
                                    StrokeThickness="2"
                                    Stroke="{AppThemeBinding Light=#CBD5E1, Dark=#334155}"
                                    WidthRequest="80" HeightRequest="80">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="24"/>
                                </Border.StrokeShape>
                                <!-- ADDED: tap to change photo -->
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnAvatarTapped"/>
                                </Border.GestureRecognizers>
                                <Grid>
                                    <Label x:Name="AvatarLabel"
                                           Text="👤" FontSize="40"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                    <Image x:Name="AvatarImage"
                                           Aspect="AspectFill"
                                           IsVisible="False"
                                           HorizontalOptions="Fill"
                                           VerticalOptions="Fill"/>
                                </Grid>
                            </Border>

                            <!-- Online dot (unchanged) -->
                            <Border BackgroundColor="#22C55E"
                                    StrokeThickness="2"
                                    Stroke="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                    WidthRequest="16" HeightRequest="16"
                                    HorizontalOptions="End" VerticalOptions="End"
                                    Margin="0,0,2,2">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                            </Border>

                            <!-- ADDED: camera badge top-right -->
                            <Border BackgroundColor="#3B82F6"
                                    StrokeThickness="1.5"
                                    Stroke="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                    WidthRequest="24" HeightRequest="24"
                                    HorizontalOptions="End" VerticalOptions="Start">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnAvatarTapped"/>
                                </Border.GestureRecognizers>
                                <Label Text="📷" FontSize="11"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                        </Grid>
                        <!-- ── End Avatar ── -->

                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label x:Name="FullNameLabel"
                                   Text="Loading..."
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                            <Label x:Name="EmailLabel"
                                   Text="" FontSize="13"
                                   TextColor="#64748B"/>
                            <Border BackgroundColor="#1E40AF20"
                                    StrokeThickness="1" Stroke="#3B82F6"
                                    Padding="10,4" HorizontalOptions="Start"
                                    Margin="0,4,0,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label Text="⚡ Student"
                                       FontSize="11" FontAttributes="Bold"
                                       TextColor="#3B82F6"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- ── Stats Row ── -->
                    <Grid ColumnDefinitions="*,*,*"
                          Padding="24,20,24,0" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                Padding="0,18">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Label Text="🏅" FontSize="26" HorizontalOptions="Center"/>
                                <Label x:Name="CoursesCompletedLabel" Text="0"
                                       FontSize="24" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                                       HorizontalOptions="Center"/>
                                <Label Text="Courses" FontSize="10" TextColor="#64748B"
                                       FontAttributes="Bold" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                Padding="0,18">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Label Text="⏱️" FontSize="26" HorizontalOptions="Center"/>
                                <Label x:Name="TotalHoursLabel" Text="0"
                                       FontSize="24" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                                       HorizontalOptions="Center"/>
                                <Label Text="Hours" FontSize="10" TextColor="#64748B"
                                       FontAttributes="Bold" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="2"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                Padding="0,18">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Label Text="📜" FontSize="26" HorizontalOptions="Center"/>
                                <Label x:Name="CertificatesLabel" Text="0"
                                       FontSize="24" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                                       HorizontalOptions="Center"/>
                                <Label Text="Certs" FontSize="10" TextColor="#64748B"
                                       FontAttributes="Bold" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- ── Section Label ── -->
                    <Label Text="ACCOUNT"
                           FontSize="11" FontAttributes="Bold"
                           TextColor="#475569" CharacterSpacing="2"
                           Margin="24,28,24,12"/>

                    <!-- ── Menu Items ── -->
                    <VerticalStackLayout Padding="24,0" Spacing="10">

                        <!-- ── Settings (Collapsible) ── -->
                        <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="0">

                                <!-- Settings header row -->
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="18,14">
                                    <Border Grid.Column="0"
                                            BackgroundColor="#3B82F620"
                                            StrokeThickness="0"
                                            WidthRequest="38" HeightRequest="38"
                                            Margin="0,0,14,0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="11"/>
                                        </Border.StrokeShape>
                                        <Image Source="setting.png"
                                               HeightRequest="20" WidthRequest="20"
                                               Aspect="AspectFit"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="Settings"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                                        <Label Text="Manage your preferences"
                                               FontSize="12" TextColor="#64748B"/>
                                    </VerticalStackLayout>
                                    <Label x:Name="SettingsChevron"
                                           Grid.Column="2"
                                           Text="›" FontSize="22"
                                           TextColor="#475569"
                                           VerticalOptions="Center"/>
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSettingsToggled"/>
                                    </Grid.GestureRecognizers>
                                </Grid>

                                <!-- Expandable sub-items -->
                                <VerticalStackLayout x:Name="SettingsPanel"
                                                     IsVisible="False"
                                                     Padding="12,0,12,12"
                                                     Spacing="4">

                                    <BoxView HeightRequest="1"
                                             Color="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                             Margin="6,0,6,8"/>

                                    <!-- Edit Profile -->
                                    <Border BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                            StrokeThickness="0" Padding="14,12">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnEditProfileTapped"/>
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0"
                                                    BackgroundColor="#3B82F620"
                                                    StrokeThickness="0"
                                                    WidthRequest="34" HeightRequest="34"
                                                    Margin="0,0,12,0">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Image Source="edit.png"
                                                       HeightRequest="17" WidthRequest="17"
                                                       Aspect="AspectFit"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                                <Label Text="Edit Profile"
                                                       FontSize="14" FontAttributes="Bold"
                                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                                                <Label Text="Update your personal info"
                                                       FontSize="11" TextColor="#64748B"/>
                                            </VerticalStackLayout>
                                            <Label Grid.Column="2" Text="›"
                                                   FontSize="20" TextColor="#475569"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Dark Mode Toggle -->
                                    <Border BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                            StrokeThickness="0" Padding="14,12">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0"
                                                    BackgroundColor="#F59E0B20"
                                                    StrokeThickness="0"
                                                    WidthRequest="34" HeightRequest="34"
                                                    Margin="0,0,12,0">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Label Text="{AppThemeBinding Light=🌙, Dark=☀️}"
                                                       FontSize="17"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                                <Label Text="Light Mode"
                                                       FontSize="14" FontAttributes="Bold"
                                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                                                <Label Text="{AppThemeBinding Light='Switch to dark theme', Dark='Switch to light theme'}"
                                                       FontSize="11" TextColor="#64748B"/>
                                            </VerticalStackLayout>
                                            <Switch Grid.Column="2"
                                                    x:Name="ThemeSwitch"
                                                    IsToggled="False"
                                                    OnColor="#3B82F6"
                                                    VerticalOptions="Center"
                                                    Toggled="OnThemeToggled"/>
                                        </Grid>
                                    </Border>

                                    <!-- Privacy & Security -->
                                    <Border BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                            StrokeThickness="0" Padding="14,12">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnPrivacyTapped"/>
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0"
                                                    BackgroundColor="#22C55E20"
                                                    StrokeThickness="0"
                                                    WidthRequest="34" HeightRequest="34"
                                                    Margin="0,0,12,0">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Image Source="privacy.png"
                                                       HeightRequest="17" WidthRequest="17"
                                                       Aspect="AspectFit"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                                <Label Text="Privacy &amp; Security"
                                                       FontSize="14" FontAttributes="Bold"
                                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                                                <Label Text="Control your data and privacy"
                                                       FontSize="11" TextColor="#64748B"/>
                                            </VerticalStackLayout>
                                            <Label Grid.Column="2" Text="›"
                                                   FontSize="20" TextColor="#475569"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Help & Support -->
                                    <Border BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                            StrokeThickness="0" Padding="14,12">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnHelpTapped"/>
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0"
                                                    BackgroundColor="#8B5CF620"
                                                    StrokeThickness="0"
                                                    WidthRequest="34" HeightRequest="34"
                                                    Margin="0,0,12,0">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Image Source="ic_help.png"
                                                       HeightRequest="17" WidthRequest="17"
                                                       Aspect="AspectFit"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                                <Label Text="Help &amp; Support"
                                                       FontSize="14" FontAttributes="Bold"
                                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                                                <Label Text="FAQs and contact support"
                                                       FontSize="11" TextColor="#64748B"/>
                                            </VerticalStackLayout>
                                            <Label Grid.Column="2" Text="›"
                                                   FontSize="20" TextColor="#475569"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>

                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!-- ── Leaderboard ── -->
                        <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLeaderboardTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="18,14">
                                <Border Grid.Column="0"
                                        BackgroundColor="#F59E0B20"
                                        StrokeThickness="0"
                                        WidthRequest="38" HeightRequest="38"
                                        Margin="0,0,14,0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="11"/>
                                    </Border.StrokeShape>
                                    <Image Source="leader.png"
                                           HeightRequest="20" WidthRequest="20"
                                           Aspect="AspectFit"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="Leaderboard"
                                           FontSize="15" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                                    <Label Text="See how you rank among peers"
                                           FontSize="12" TextColor="#64748B"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="2"
                                       Text="›" FontSize="22"
                                       TextColor="#475569"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- ── Meetings ── -->
                        <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMeetingsTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="18,14">
                                <Border Grid.Column="0"
                                        BackgroundColor="#22C55E20"
                                        StrokeThickness="0"
                                        WidthRequest="38" HeightRequest="38"
                                        Margin="0,0,14,0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="11"/>
                                    </Border.StrokeShape>
                                    <Image Source="meeting.png"
                                           HeightRequest="20" WidthRequest="20"
                                           Aspect="AspectFit"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="Meetings"
                                           FontSize="15" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                                    <Label Text="Schedule and join sessions"
                                           FontSize="12" TextColor="#64748B"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="2"
                                       Text="›" FontSize="22"
                                       TextColor="#475569"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                    </VerticalStackLayout>

                    <BoxView HeightRequest="24" Color="Transparent"/>

                    <!-- ── Logout Button ── -->
                    <Border Margin="24,0"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Button Text="Sign Out"
                                TextColor="#EF4444"
                                BackgroundColor="Transparent"
                                FontSize="15" FontAttributes="Bold"
                                HeightRequest="54"
                                Clicked="OnLogoutClicked"/>
                    </Border>

                    <Label Text="Devinity v1.0.0"
                           FontSize="12" TextColor="#334155"
                           HorizontalOptions="Center"
                           Margin="0,20,0,40"/>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
