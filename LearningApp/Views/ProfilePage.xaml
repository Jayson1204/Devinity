<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:LearningApp.Controls"
             x:Class="LearningApp.Views.ProfilePage"
             BackgroundColor="#0F172A"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0" RowDefinitions="*">

            <!-- Skeleton State -->
            <ScrollView x:Name="SkeletonScroll" IsVisible="True">
                <VerticalStackLayout Spacing="0" BackgroundColor="#0F172A">
                    <VerticalStackLayout BackgroundColor="#0F172A" Padding="24,60,24,24" Spacing="14">
                        <controls:SkeletonView WidthRequest="80" HeightRequest="80"
                                               CornerRadius="40" HorizontalOptions="Start"/>
                        <controls:SkeletonView HeightRequest="22" WidthRequest="160"
                                               CornerRadius="6" HorizontalOptions="Start"/>
                        <controls:SkeletonView HeightRequest="14" WidthRequest="220"
                                               CornerRadius="6" HorizontalOptions="Start"/>
                    </VerticalStackLayout>
                    <Grid ColumnDefinitions="*,*,*" Padding="24,0,24,24" ColumnSpacing="12">
                        <controls:SkeletonView Grid.Column="0" HeightRequest="100" CornerRadius="20"/>
                        <controls:SkeletonView Grid.Column="1" HeightRequest="100" CornerRadius="20"/>
                        <controls:SkeletonView Grid.Column="2" HeightRequest="100" CornerRadius="20"/>
                    </Grid>
                    <VerticalStackLayout Padding="24,0" Spacing="12">
                        <controls:SkeletonView HeightRequest="60" CornerRadius="16"/>
                        <controls:SkeletonView HeightRequest="60" CornerRadius="16"/>
                        <controls:SkeletonView HeightRequest="60" CornerRadius="16"/>
                        <controls:SkeletonView HeightRequest="60" CornerRadius="16"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>

            <!-- Real Content -->
            <ScrollView x:Name="ContentScroll" IsVisible="False">
                <VerticalStackLayout Spacing="0" BackgroundColor="#0F172A">

                    <!-- ── Profile Header ── -->
                    <Grid RowDefinitions="Auto,Auto" BackgroundColor="#0F172A" Padding="24,60,24,0">

                        <!-- Avatar + Info -->
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="16">

                            <!-- Avatar -->
                            <Grid Grid.Column="0">
                                <Border BackgroundColor="#1E293B"
                                        StrokeThickness="2"
                                        Stroke="#334155"
                                        WidthRequest="80"
                                        HeightRequest="80">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="24"/>
                                    </Border.StrokeShape>
                                    <Label Text="👤"
                                           FontSize="40"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <!-- Online dot -->
                                <Border BackgroundColor="#22C55E"
                                        StrokeThickness="2"
                                        Stroke="#0F172A"
                                        WidthRequest="16"
                                        HeightRequest="16"
                                        HorizontalOptions="End"
                                        VerticalOptions="End"
                                        Margin="0,0,2,2">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                </Border>
                            </Grid>

                            <!-- Name + Email + Badge -->
                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                <Label x:Name="FullNameLabel"
                                       Text="Loading..."
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#F8FAFC"/>
                                <Label x:Name="EmailLabel"
                                       Text=""
                                       FontSize="13"
                                       TextColor="#64748B"/>
                                <Border BackgroundColor="#1E40AF20"
                                        StrokeThickness="1"
                                        Stroke="#3B82F6"
                                        Padding="10,4"
                                        HorizontalOptions="Start"
                                        Margin="0,4,0,0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Label Text="⚡ Student"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="#3B82F6"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>
                    </Grid>

                    <!-- ── Stats Row ── -->
                    <Grid ColumnDefinitions="*,*,*"
                          Padding="24,20,24,0"
                          ColumnSpacing="12">

                        <!-- Courses -->
                        <Border Grid.Column="0"
                                BackgroundColor="#1E293B"
                                StrokeThickness="1"
                                Stroke="#334155"
                                Padding="0,18">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Label Text="🏅" FontSize="26" HorizontalOptions="Center"/>
                                <Label x:Name="CoursesCompletedLabel"
                                       Text="0"
                                       FontSize="24"
                                       FontAttributes="Bold"
                                       TextColor="#F8FAFC"
                                       HorizontalOptions="Center"/>
                                <Label Text="Courses"
                                       FontSize="10"
                                       TextColor="#64748B"
                                       FontAttributes="Bold"
                                       CharacterSpacing="0.5"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Hours -->
                        <Border Grid.Column="1"
                                BackgroundColor="#1E293B"
                                StrokeThickness="1"
                                Stroke="#334155"
                                Padding="0,18">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Label Text="⏱️" FontSize="26" HorizontalOptions="Center"/>
                                <Label x:Name="TotalHoursLabel"
                                       Text="0"
                                       FontSize="24"
                                       FontAttributes="Bold"
                                       TextColor="#F8FAFC"
                                       HorizontalOptions="Center"/>
                                <Label Text="Hours"
                                       FontSize="10"
                                       TextColor="#64748B"
                                       FontAttributes="Bold"
                                       CharacterSpacing="0.5"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Certificates -->
                        <Border Grid.Column="2"
                                BackgroundColor="#1E293B"
                                StrokeThickness="1"
                                Stroke="#334155"
                                Padding="0,18">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Label Text="📜" FontSize="26" HorizontalOptions="Center"/>
                                <Label x:Name="CertificatesLabel"
                                       Text="0"
                                       FontSize="24"
                                       FontAttributes="Bold"
                                       TextColor="#F8FAFC"
                                       HorizontalOptions="Center"/>
                                <Label Text="Certs"
                                       FontSize="10"
                                       TextColor="#64748B"
                                       FontAttributes="Bold"
                                       CharacterSpacing="0.5"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- ── Section Label ── -->
                    <Label Text="ACCOUNT"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#475569"
                           CharacterSpacing="2"
                           Margin="24,28,24,12"/>

                    <!-- ── Menu Items ── -->
                    <VerticalStackLayout Padding="24,0" Spacing="10">

                        <!-- Edit Profile -->
                        <Border BackgroundColor="#1E293B"
                                StrokeThickness="1"
                                Stroke="#334155"
                                Padding="18,14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Grid.Column="0"
                                        BackgroundColor="#3B82F620"
                                        StrokeThickness="0"
                                        WidthRequest="38"
                                        HeightRequest="38"
                                        Margin="0,0,14,0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="11"/>
                                    </Border.StrokeShape>
                                    <Label Text="👤"
                                           FontSize="18"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="Edit Profile"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#F8FAFC"/>
                                    <Label Text="Update your personal info"
                                           FontSize="12"
                                           TextColor="#64748B"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="2"
                                       Text="›"
                                       FontSize="22"
                                       TextColor="#475569"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Notifications -->
                        <Border BackgroundColor="#1E293B"
                                StrokeThickness="1"
                                Stroke="#334155"
                                Padding="18,14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Grid.Column="0"
                                        BackgroundColor="#F59E0B20"
                                        StrokeThickness="0"
                                        WidthRequest="38"
                                        HeightRequest="38"
                                        Margin="0,0,14,0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="11"/>
                                    </Border.StrokeShape>
                                    <Label Text="🔔"
                                           FontSize="18"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="Notifications"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#F8FAFC"/>
                                    <Label Text="Manage alerts and reminders"
                                           FontSize="12"
                                           TextColor="#64748B"/>
                                </VerticalStackLayout>
                                <Switch Grid.Column="2"
                                        IsToggled="True"
                                        OnColor="#3B82F6"
                                        VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Privacy -->
                        <Border BackgroundColor="#1E293B"
                                StrokeThickness="1"
                                Stroke="#334155"
                                Padding="18,14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Grid.Column="0"
                                        BackgroundColor="#22C55E20"
                                        StrokeThickness="0"
                                        WidthRequest="38"
                                        HeightRequest="38"
                                        Margin="0,0,14,0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="11"/>
                                    </Border.StrokeShape>
                                    <Label Text="🔒"
                                           FontSize="18"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="Privacy &amp; Security"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#F8FAFC"/>
                                    <Label Text="Control your data and privacy"
                                           FontSize="12"
                                           TextColor="#64748B"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="2"
                                       Text="›"
                                       FontSize="22"
                                       TextColor="#475569"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Help -->
                        <Border BackgroundColor="#1E293B"
                                StrokeThickness="1"
                                Stroke="#334155"
                                Padding="18,14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Grid.Column="0"
                                        BackgroundColor="#8B5CF620"
                                        StrokeThickness="0"
                                        WidthRequest="38"
                                        HeightRequest="38"
                                        Margin="0,0,14,0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="11"/>
                                    </Border.StrokeShape>
                                    <Label Text="❓"
                                           FontSize="18"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="Help &amp; Support"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#F8FAFC"/>
                                    <Label Text="FAQs and contact support"
                                           FontSize="12"
                                           TextColor="#64748B"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="2"
                                       Text="›"
                                       FontSize="22"
                                       TextColor="#475569"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Meetings -->
                        <Border BackgroundColor="#1E293B"
                                StrokeThickness="1"
                                Stroke="#334155"
                                Padding="18,14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Grid.Column="0"
                                        BackgroundColor="#EC489920"
                                        StrokeThickness="0"
                                        WidthRequest="38"
                                        HeightRequest="38"
                                        Margin="0,0,14,0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="11"/>
                                    </Border.StrokeShape>
                                    <Label Text="👥"
                                           FontSize="18"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="Meetings"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#F8FAFC"/>
                                    <Label Text="Schedule and join sessions"
                                           FontSize="12"
                                           TextColor="#64748B"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="2"
                                       Text="›"
                                       FontSize="22"
                                       TextColor="#475569"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                    </VerticalStackLayout>

                    <BoxView HeightRequest="24" Color="Transparent"/>

                    <!-- ── Logout Button ── -->
                    <Border Margin="24,0"
                            BackgroundColor="#7F1D1D20"
                            StrokeThickness="1"
                            Stroke="#EF4444"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Button Text="Sign Out"
                                TextColor="#EF4444"
                                BackgroundColor="Transparent"
                                FontSize="15"
                                FontAttributes="Bold"
                                HeightRequest="54"
                                Clicked="OnLogoutClicked"/>
                    </Border>

                    <!-- Version -->
                    <Label Text="Devinity v1.0.0"
                           FontSize="12"
                           TextColor="#334155"
                           HorizontalOptions="Center"
                           Margin="0,20,0,40"/>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

    </Grid>
</ContentPage>
