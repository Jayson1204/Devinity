<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:LearningApp.ViewModels"
             xmlns:skia="clr-namespace:SkiaSharp.Extended.UI.Controls;assembly=SkiaSharp.Extended.UI"
             x:Class="LearningApp.Views.RegisterPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0F172A">
    <ContentPage.BindingContext>
        <viewmodels:RegisterViewModel />
    </ContentPage.BindingContext>

    <Grid>

        <!-- Background accent blobs -->
        <Ellipse Fill="#8B5CF6"
                 WidthRequest="300" HeightRequest="300"
                 VerticalOptions="Start" HorizontalOptions="Start"
                 TranslationX="-100" TranslationY="-100"
                 Opacity="0.06"/>
        <Ellipse Fill="#3B82F6"
                 WidthRequest="250" HeightRequest="250"
                 VerticalOptions="End" HorizontalOptions="End"
                 TranslationX="80" TranslationY="80"
                 Opacity="0.06"/>

        <ScrollView>
            <VerticalStackLayout Padding="28" Spacing="0" VerticalOptions="Center">

                <!-- ── Header ── -->
                <VerticalStackLayout Spacing="10" Margin="0,60,0,32" HorizontalOptions="Center">
                    <Label Text="Create Account"
                           FontSize="30" FontAttributes="Bold"
                           TextColor="#F8FAFC"
                           HorizontalOptions="Center"
                           Margin="0,8,0,0"/>
                    <Label Text="Join and start learning today"
                           FontSize="15" TextColor="#64748B"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- ── Error / Success Banners ── -->
                <VerticalStackLayout Spacing="10" Margin="0,0,0,16">
                    <Border BackgroundColor="#7F1D1D20" Stroke="#EF4444"
                            StrokeThickness="1" Padding="16,12"
                            IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="⚠️" FontSize="16" VerticalOptions="Center"/>
                            <Label Text="{Binding ErrorMessage}"
                                   TextColor="#EF4444" FontSize="13"
                                   LineBreakMode="WordWrap" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>
                    <Border BackgroundColor="#14532D20" Stroke="#22C55E"
                            StrokeThickness="1" Padding="16,12"
                            IsVisible="{Binding SuccessMessage, Converter={StaticResource StringToBoolConverter}}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="✅" FontSize="16" VerticalOptions="Center"/>
                            <Label Text="{Binding SuccessMessage}"
                                   TextColor="#22C55E" FontSize="13"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ── Form Card ── -->
                <Border BackgroundColor="#1E293B"
                        StrokeThickness="1" Stroke="#334155"
                        Padding="28,36" MaximumWidthRequest="450">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="28">

                        <!-- Full Name -->
                        <VerticalStackLayout Spacing="0">
                            <Label Text="FULL NAME"
                                   TextColor="#475569" FontSize="11"
                                   FontAttributes="Bold" CharacterSpacing="2"
                                   Margin="0,0,0,8"/>
                            <Entry Text="{Binding FullName}"
                                   Placeholder="Enter your full name"
                                   TextColor="#F8FAFC"
                                   PlaceholderColor="#334155"
                                   FontSize="16"
                                   BackgroundColor="Transparent"/>
                            <BoxView HeightRequest="1.5"
                                     BackgroundColor="#475569"
                                     Margin="0,1,0,0"/>
                            <Label Text="{Binding FullNameError}"
                                   TextColor="#EF4444" FontSize="12"
                                   Margin="0,6,0,0"
                                   IsVisible="{Binding FullNameError, Converter={StaticResource StringToBoolConverter}}"/>
                        </VerticalStackLayout>

                        <!-- Email -->
                        <VerticalStackLayout Spacing="0">
                            <Label Text="EMAIL"
                                   TextColor="#475569" FontSize="11"
                                   FontAttributes="Bold" CharacterSpacing="2"
                                   Margin="0,0,0,8"/>
                            <Entry Text="{Binding Email}"
                                   Placeholder="name@example.com"
                                   Keyboard="Email"
                                   TextColor="#F8FAFC"
                                   PlaceholderColor="#334155"
                                   FontSize="16"
                                   BackgroundColor="Transparent"/>
                            <BoxView HeightRequest="1.5"
                                     BackgroundColor="#475569"
                                     Margin="0,1,0,0"/>
                            <Label Text="{Binding EmailError}"
                                   TextColor="#EF4444" FontSize="12"
                                   Margin="0,6,0,0"
                                   IsVisible="{Binding EmailError, Converter={StaticResource StringToBoolConverter}}"/>
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="0">
                            <Label Text="PASSWORD"
                                   TextColor="#475569" FontSize="11"
                                   FontAttributes="Bold" CharacterSpacing="2"
                                   Margin="0,0,0,8"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <Entry Grid.Column="0"
                                       Text="{Binding Password}"
                                       Placeholder="••••••••"
                                       IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                                       TextColor="#F8FAFC"
                                       PlaceholderColor="#334155"
                                       FontSize="16"
                                       BackgroundColor="Transparent"/>
                                <ImageButton Grid.Column="1"
                                             Command="{Binding TogglePasswordVisibilityCommand}"
                                             Source="{Binding IsPasswordVisible, Converter={StaticResource PasswordIconConverter}}"
                                             WidthRequest="22" HeightRequest="22"
                                             BackgroundColor="Transparent"
                                             VerticalOptions="Center"/>
                            </Grid>
                            <BoxView HeightRequest="1.5"
                                     BackgroundColor="#475569"
                                     Margin="0,1,0,0"/>
                            <Label Text="{Binding PasswordError}"
                                   TextColor="#EF4444" FontSize="12"
                                   Margin="0,6,0,0"
                                   IsVisible="{Binding PasswordError, Converter={StaticResource StringToBoolConverter}}"/>
                        </VerticalStackLayout>

                        <!-- Confirm Password -->
                        <VerticalStackLayout Spacing="0">
                            <Label Text="CONFIRM PASSWORD"
                                   TextColor="#475569" FontSize="11"
                                   FontAttributes="Bold" CharacterSpacing="2"
                                   Margin="0,0,0,8"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <Entry Grid.Column="0"
                                       Text="{Binding ConfirmPassword}"
                                       Placeholder="••••••••"
                                       IsPassword="{Binding IsConfirmPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                                       TextColor="#F8FAFC"
                                       PlaceholderColor="#334155"
                                       FontSize="16"
                                       BackgroundColor="Transparent"/>
                                <ImageButton Grid.Column="1"
                                             Command="{Binding ToggleConfirmPasswordVisibilityCommand}"
                                             Source="{Binding IsConfirmPasswordVisible, Converter={StaticResource PasswordIconConverter}}"
                                             WidthRequest="22" HeightRequest="22"
                                             BackgroundColor="Transparent"
                                             VerticalOptions="Center"/>
                            </Grid>
                            <BoxView HeightRequest="1.5"
                                     BackgroundColor="#475569"
                                     Margin="0,1,0,0"/>
                            <Label Text="{Binding ConfirmPasswordError}"
                                   TextColor="#EF4444" FontSize="12"
                                   Margin="0,6,0,0"
                                   IsVisible="{Binding ConfirmPasswordError, Converter={StaticResource StringToBoolConverter}}"/>
                        </VerticalStackLayout>

                        <!-- Create Account Button -->
                        <Border BackgroundColor="#3B82F6"
                                StrokeThickness="0" Margin="0,4,0,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Button Text="Create Account"
                                    Command="{Binding RegisterCommand}"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                                    BackgroundColor="Transparent"
                                    TextColor="White"
                                    FontSize="16" FontAttributes="Bold"
                                    HeightRequest="54">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Text" Value="Creating Account..."/>
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- ── Login Link ── -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="6" Margin="0,24,0,40">
                    <Label Text="Already have an account?" TextColor="#64748B" FontSize="14"/>
                    <Label Text="Sign In" TextColor="#3B82F6"
                           FontSize="14" FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToLoginCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Loading Overlay ── -->
        <Grid IsVisible="{Binding IsLoading}" BackgroundColor="#990F172A">
            <Border BackgroundColor="#1E293B"
                    StrokeThickness="1" Stroke="#334155"
                    Padding="40,32"
                    HorizontalOptions="Center" VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <skia:SKLottieView Source="loading.json"
                                       RepeatCount="-1"
                                       WidthRequest="80"
                                       HeightRequest="80"
                                       HorizontalOptions="Center"/>
                    <Label Text="Creating Account..."
                           TextColor="#F8FAFC" FontSize="15"
                           FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>