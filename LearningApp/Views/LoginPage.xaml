<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:LearningApp.ViewModels"
             xmlns:skia="clr-namespace:SkiaSharp.Extended.UI.Controls;assembly=SkiaSharp.Extended.UI"
             x:Class="LearningApp.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0F172A">
    <ContentPage.BindingContext>
        <viewmodels:LoginViewModel />
    </ContentPage.BindingContext>

    <Grid>

        <!-- Background accent blobs -->
        <Ellipse Fill="#3B82F6"
                 WidthRequest="350" HeightRequest="350"
                 VerticalOptions="Start" HorizontalOptions="End"
                 TranslationX="140" TranslationY="-140"
                 Opacity="0.06"/>
        <Ellipse Fill="#8B5CF6"
                 WidthRequest="250" HeightRequest="250"
                 VerticalOptions="End" HorizontalOptions="Start"
                 TranslationX="-80" TranslationY="80"
                 Opacity="0.06"/>

        <ScrollView>
            <VerticalStackLayout Padding="28" Spacing="0" VerticalOptions="Center">

                <!-- ── Header ── -->
                <VerticalStackLayout Spacing="10" Margin="0,60,0,40" HorizontalOptions="Center">
                    <Label Text="Login"
                           FontSize="30" FontAttributes="Bold"
                           TextColor="#F8FAFC"
                           HorizontalOptions="Center"
                           Margin="0,8,0,0"/>
                    <Label Text="Sign in to continue your journey"
                           FontSize="15" TextColor="#64748B"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- ── Form Card ── -->
                <Border BackgroundColor="#1E293B"
                        StrokeThickness="1" Stroke="#334155"
                        Padding="28,36" MaximumWidthRequest="450">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="32">

                        <!-- Email -->
                        <VerticalStackLayout Spacing="0">
                            <Label Text="EMAIL"
           TextColor="#475569" FontSize="11"
           FontAttributes="Bold" CharacterSpacing="2"
           Margin="0,0,0,4"/>
                            <Border StrokeThickness="0" BackgroundColor="Transparent" Padding="0">
                                <Entry Text="{Binding Email}"
               Placeholder="username"
               Keyboard="Email"
               TextColor="#F8FAFC"
               PlaceholderColor="#334155"
               FontSize="16"
               BackgroundColor="Transparent"
               HeightRequest="35" 
               Margin="0,0,0,-8"/>
                            </Border>

                            <BoxView HeightRequest="1"
             BackgroundColor="#475569"
             HorizontalOptions="Fill"
             Margin="0,0,0,0"/>

                            <Label Text="{Binding EmailError}"
           TextColor="#EF4444" FontSize="12"
           Margin="0,6,0,0"
           IsVisible="{Binding EmailError, Converter={StaticResource StringToBoolConverter}}"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="0">
                            <Label Text="PASSWORD"
           TextColor="#475569" FontSize="11"
           FontAttributes="Bold" CharacterSpacing="2"
           Margin="0,18,0,4"/>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="0">
                                <Border Grid.Column="0" StrokeThickness="0" BackgroundColor="Transparent" Padding="0">
                                    <Entry Text="{Binding Password}"
                   Placeholder="••••••••"
                   IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                   TextColor="#F8FAFC"
                   PlaceholderColor="#334155"
                   FontSize="16"
                   BackgroundColor="Transparent"
                   HeightRequest="35"
                   Margin="0,0,0,-8"/>
                                </Border>

                                <Label Grid.Column="1"
               Text="{Binding IsPasswordVisible, Converter={StaticResource PasswordIconConverter}}"
               FontSize="20"
               TextColor="#64748B"
               VerticalOptions="Center"
               Padding="8,0,0,5">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>

                            <BoxView HeightRequest="1"
             BackgroundColor="#475569"
             HorizontalOptions="Fill"
             Margin="0,0,0,0"/>

                            <Label Text="{Binding PasswordError}"
           TextColor="#EF4444" FontSize="12"
           Margin="0,6,0,0"
           IsVisible="{Binding PasswordError, Converter={StaticResource StringToBoolConverter}}"/>
                        </VerticalStackLayout>

                        <!-- API Error -->
                        <Border BackgroundColor="#7F1D1D20"
                                StrokeThickness="1" Stroke="#EF4444"
                                Padding="14,10"
                                IsVisible="{Binding ApiError, Converter={StaticResource StringToBoolConverter}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Label Text="{Binding ApiError}"
                                   TextColor="#EF4444" FontSize="13"
                                   HorizontalOptions="Center"/>
                        </Border>

                        <!-- Sign In Button -->
                        <Border BackgroundColor="#3B82F6"
                                StrokeThickness="0" Margin="0,4,0,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Button Text="Sign In"
                                    Command="{Binding LoginCommand}"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                                    BackgroundColor="Transparent"
                                    TextColor="White"
                                    FontSize="16" FontAttributes="Bold"
                                    HeightRequest="54">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Text" Value="Authenticating..."/>
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- ── Register Link ── -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="6" Margin="0,24,0,40">
                    <Label Text="Don't have an account?" TextColor="#64748B" FontSize="14"/>
                    <Label Text="Register" TextColor="#3B82F6"
                           FontSize="14" FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToRegisterCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Loading Overlay ── -->
        <Grid IsVisible="{Binding IsLoading}" BackgroundColor="#990F172A">
            <Border BackgroundColor="#1E293B"
                    StrokeThickness="1" Stroke="#334155"
                    Padding="40,32"
                    HorizontalOptions="Center" VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <skia:SKLottieView Source="loading.json"
                                       RepeatCount="-1"
                                       WidthRequest="80"
                                       HeightRequest="80"
                                       HorizontalOptions="Center"/>
                    <Label Text="Signing In..."
                           TextColor="#F8FAFC" FontSize="15"
                           FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
