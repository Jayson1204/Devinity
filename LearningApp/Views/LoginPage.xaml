<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:LearningApp.ViewModels"
             x:Class="LearningApp.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#30364F">
    <ContentPage.BindingContext>
        <viewmodels:LoginViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <Ellipse Fill="#F0F0DB" WidthRequest="300" HeightRequest="300" 
                 VerticalOptions="Start" HorizontalOptions="End" 
                 TranslationX="100" TranslationY="-100" Opacity="0.5"/>

        <ScrollView>
            <VerticalStackLayout Padding="30" Spacing="0" VerticalOptions="Center">

                <VerticalStackLayout Spacing="15" Margin="0,20,0,40">

                    

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Welcome Back" 
                               FontSize="32" 
                               FontAttributes="Bold"
                               TextColor="#ACBAC4"
                               HorizontalOptions="Center" />

                        <Label Text="Sign in to continue your journey" 
                               FontSize="16" 
                               TextColor="#ACBAC4"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <Border BackgroundColor="White" 
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 32" 
                        Padding="28"
                        MaximumWidthRequest="450">
                    <Border.Shadow>
                        <Shadow Brush="#020202" Offset="0,10" Radius="30" Opacity="0.1" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="20">

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Email Address" TextColor="#503B31" FontSize="14" FontAttributes="Bold" Margin="4,0"/>
                            <Border Stroke="{Binding EmailError, Converter={StaticResource StringToBorderColorConverter}}"
                                    StrokeThickness="1.5"
                                    BackgroundColor="#F0F0DB"
                                    StrokeShape="RoundRectangle 16">
                                <Entry Text="{Binding Email}"
                                       Placeholder="name@example.com"
                                       Keyboard="Email"
                                       TextColor="#020202"
                                       PlaceholderColor="#30364F"
                                       FontSize="15"
                                       Margin="15,5" />
                            </Border>
                            <Label Text="{Binding EmailError}" 
                                   TextColor="#EF4444"
                                   FontSize="12"
                                   Margin="4,0"
                                   IsVisible="{Binding EmailError, Converter={StaticResource StringToBoolConverter}}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Password" TextColor="#503B31" FontSize="14" FontAttributes="Bold" Margin="4,0"/>
                            <Border Stroke="{Binding PasswordError, Converter={StaticResource StringToBorderColorConverter}}"
                                    StrokeThickness="1.5"
                                    BackgroundColor="#F0F0DB"
                                    StrokeShape="RoundRectangle 16">
                                <Grid ColumnDefinitions="*, Auto" Margin="15,5">
                                    <Entry Grid.Column="0"
                                           Text="{Binding Password}"
                                           Placeholder="••••••••"
                                           IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                                           TextColor="#020202"
                                           PlaceholderColor="#9097C0"
                                           FontSize="15" />

                                    <ImageButton Grid.Column="1"
                                                 Command="{Binding TogglePasswordVisibilityCommand}"
                                                 Source="{Binding IsPasswordVisible, Converter={StaticResource PasswordIconConverter}}"
                                                 WidthRequest="22"
                                                 HeightRequest="22"
                                                 Aspect="AspectFit"
                                                 BackgroundColor="Transparent"
                                                 VerticalOptions="Center" />
                                </Grid>
                            </Border>
                            <Label Text="{Binding PasswordError}" 
                                   TextColor="#EF4444"
                                   FontSize="12"
                                   Margin="4,0"
                                   IsVisible="{Binding PasswordError, Converter={StaticResource StringToBoolConverter}}" />
                        </VerticalStackLayout>

                        <Label Text="{Binding ApiError}" 
                               TextColor="#EF4444"
                               FontSize="13"
                               HorizontalOptions="Center"
                               IsVisible="{Binding ApiError, Converter={StaticResource StringToBoolConverter}}" />

                        <Button Text="Login"
                                Command="{Binding LoginCommand}"
                                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                                BackgroundColor="#30364F" 
                                TextColor="White"
                                FontSize="17"
                                FontAttributes="Bold"
                                CornerRadius="16"
                                HeightRequest="58"
                                Margin="0,10,0,0">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Text" Value="Authenticating..." />
                                    <Setter Property="Opacity" Value="0.8" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                    </VerticalStackLayout>
                </Border>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,25">
                    <Label Text="Don't have an account?" TextColor="#ACBAC4" FontSize="15" />
                    <Label Text="Register" 
                           TextColor="#ACBAC4"
                           FontSize="15"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToRegisterCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <Grid IsVisible="{Binding IsLoading}" BackgroundColor="#AA020202">
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 24"
                    Padding="40"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="{Binding IsLoading}" Color="#503B31" Scale="1.2" />
                    <Label Text="Logging In" TextColor="#020202" FontAttributes="Bold" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>