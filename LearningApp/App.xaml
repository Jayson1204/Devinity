<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:LearningApp.Converters"
             x:Class="LearningApp.App">
    <Application.Resources>
        <ResourceDictionary>

            <!-- Value Converters -->
            <converters:StringToBoolConverter x:Key="StringToBoolConverter" />
            <converters:StringToBorderColorConverter x:Key="StringToBorderColorConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:PasswordIconConverter x:Key="PasswordIconConverter" />

            <!-- Colors -->
            <Color x:Key="Primary">#4F46E5</Color>
            <Color x:Key="Secondary">#A855F7</Color>
            <Color x:Key="Accent">#EC4899</Color>
            <Color x:Key="TextPrimary">#1F2937</Color>
            <Color x:Key="TextSecondary">#6B7280</Color>
            <Color x:Key="Error">#EF4444</Color>
            <Color x:Key="Success">#10B981</Color>
            <Color x:Key="Background">#F9FAFB</Color>

        </ResourceDictionary>
    </Application.Resources>
</Application>
